// Prisma schema for AI Smart Calendar
// Run: npx prisma db push to sync with your database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  avatar        String?
  timezone      String    @default("UTC")
  preferences   Json?     // { darkMode, notifications, weekStart }
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  events        Event[]
  goals         Goal[]
  habits        Habit[]
  insights      Insight[]
  notifications Notification[]

  @@map("users")
}

model Event {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  category    String    @default("personal")
  color       String?
  location    String?
  isRecurring Boolean   @default(false)
  recurRule   String?   // iCal RRULE format
  aiAnalyzed  Boolean   @default(false)
  priority    String    @default("medium") // low, medium, high
  status      String    @default("scheduled") // scheduled, completed, cancelled
  tags        String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
  @@map("events")
}

model Goal {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  type        String    @default("short-term") // short-term, long-term
  category    String    @default("personal")
  targetDate  DateTime?
  hoursPerWeek Float?
  progress    Float     @default(0) // 0-100
  status      String    @default("active") // active, completed, paused
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model Habit {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  frequency   String    @default("daily") // daily, weekly, custom
  timeOfDay   String?   // morning, afternoon, evening
  duration    Int       @default(30) // minutes
  streak      Int       @default(0)
  completions Json      @default("[]") // array of dates
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("habits")
}

model Insight {
  id              String    @id @default(cuid())
  userId          String
  date            DateTime  @default(now())
  type            String    // daily, weekly
  productivityScore Int     // 0-100
  summary         String
  suggestions     Json      // array of suggestion strings
  timeBreakdown   Json      // { work: hours, personal: hours, etc. }
  rawAnalysis     String?   // full AI response
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("insights")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String    @default("reminder") // reminder, alert, insight
  read      Boolean   @default(false)
  eventId   String?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
